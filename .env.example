# Langfuse observability (optional, but recommended)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# OpenRouter LLM + Embeddings (only required if llm_provider=openrouter or embedding_provider=openrouter)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_EMBEDDING_MODEL=nvidia/nemotron-3-embed-1b:free

# OpenAI Embeddings (only required if embedding_provider=openai)
OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant (required for Docker; defaults to localhost for local dev)
# QDRANT_URL=http://qdrant:6333

# Redis (required for Docker; defaults to localhost for local dev)
# REDIS_URL=redis://localhost:6379/0

# Ollama (required for Docker; defaults to localhost for local dev)
# OLLAMA_BASE_URL=http://localhost:11434
